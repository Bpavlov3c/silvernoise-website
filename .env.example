# ═══════════════════════════════════════════════════════════
#  Silvernoise — Environment Variables
#  Copy to .env and fill in real values before deploying.
#  NEVER commit .env to Git.
# ═══════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────
APP_NAME="Silvernoise"
APP_ENV=production
APP_KEY=                        # Run: php artisan key:generate
APP_DEBUG=false
APP_URL=https://api.silvernoise.bg

# ── Database (PostgreSQL) ────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1               # or Hetzner managed DB host
DB_PORT=5432
DB_DATABASE=silvernoise
DB_USERNAME=silvernoise_user
DB_PASSWORD=

# ── Queue & Cache (Redis) ────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database

# ── File Storage (Cloudflare R2) ─────────────────────────────
FILESYSTEM_DISK=r2

AWS_ACCESS_KEY_ID=              # R2 Access Key ID
AWS_SECRET_ACCESS_KEY=          # R2 Secret Access Key
AWS_DEFAULT_REGION=auto
AWS_BUCKET=silvernoise-files
AWS_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true

# ── Email / SMTP ─────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@silvernoise.bg
MAIL_FROM_NAME="Silvernoise"

# ── KVZ Music API ────────────────────────────────────────────
# SECURITY: Never expose this key in frontend code or Git
KVZ_API_KEY=
KVZ_BASE_URL=https://api.kvzmusic.com/rest

# ── Laravel Sanctum ──────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=silvernoise.bg,seller.silvernoise.bg,admin.silvernoise.bg

# ── Frontend URLs (for CORS) ─────────────────────────────────
FRONTEND_URL=https://silvernoise.bg
SELLER_URL=https://seller.silvernoise.bg
ADMIN_URL=https://admin.silvernoise.bg

# ── Logging ───────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=warning
